# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# ─── Mux (Video & Live Streaming) ──────────────────────────
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_WEBHOOK_SECRET=your-mux-webhook-secret

# ─── Stripe (Payments & Ticketing) ��─────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# ─── Kevel Ad Network (formerly Adzerk) ────────────────────
# Configure these after creating your Kevel account at kevel.com
# The ad system falls back to local DB ads when these are not set
KEVEL_NETWORK_ID=
KEVEL_SITE_ID=
KEVEL_API_KEY=

# Zone IDs — create these in the Kevel dashboard and paste IDs here
KEVEL_ZONE_PODCAST_PREROLL=
KEVEL_ZONE_PODCAST_MIDROLL=
KEVEL_ZONE_VIDEO_PREROLL=
KEVEL_ZONE_LIVE_OVERLAY=
KEVEL_ZONE_FEED_BANNER=
KEVEL_ZONE_EVENT_BANNER=

# ─── Push Notifications (VAPID) ────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ─── OpenAI (AI features) ──────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ─── GIPHY (server-side proxy for GIF picker) ──────────────
GIPHY_API_KEY=your-giphy-api-key
